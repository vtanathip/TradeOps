rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the authorised owner email can read or write any collection.
    // The Cloud Function uses the Admin SDK which bypasses these rules entirely.

    match /run_requests/{id} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'tanathip.se@gmail.com';
    }

    match /signals/{id} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'tanathip.se@gmail.com';
    }
  }
}
