# Copy this file to .env and fill in values.
# Used by the LOCAL dev runner only (npm run runner).
# Cloud Functions use Firebase Secret Manager instead — see README.

# ── Firebase ──────────────────────────────────────────────────────────────────
# Path to your service account JSON (Firebase Console → Project Settings →
# Service Accounts → Generate new private key).
# Leave blank to use GOOGLE_APPLICATION_CREDENTIALS (Application Default Creds).
FIREBASE_CREDENTIALS_PATH=../firebase-credentials.json

# ── Polymarket ────────────────────────────────────────────────────────────────
# Private key is OPTIONAL — only needed for placing orders (not for read-only).
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
