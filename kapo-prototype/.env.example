# Polygon Amoy testnet RPC (public endpoint — no key required)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Your testnet wallet — never commit real values
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=

# Kalshi API key — optional for public market data; required if you get 401
# Generate at: https://kalshi.com/account/api
KALSHI_API_KEY=

# If Kalshi 401s with bearer token, switch to RSA signing:
# KALSHI_RSA_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Comma-separated Kalshi tickers to watch
WATCH_LIST=KXBTC-25APR-T60000,KXETH-25APR-T3000
